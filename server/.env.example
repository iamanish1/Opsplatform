# ========================================
# WEEK 1-4 AI ENGINE IMPLEMENTATION
# Environment Configuration File
# ========================================

# Existing configuration (keep as is)
NODE_ENV=production
PORT=5000

# Database
DATABASE_URL="mysql://user:password@localhost:3306/devhubs"

# GitHub OAuth & Integration
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="your_private_key"
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# Authentication
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRES_IN=7d

# Short-lived access tokens (15m recommended in production)
# Set this once you have refresh tokens deployed end-to-end
# During rollout, leave unset to inherit JWT_EXPIRES_IN
ACCESS_TOKEN_EXPIRY=15m

# GitHub token encryption (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — 64 hex characters (32 bytes)
GITHUB_TOKEN_ENCRYPTION_KEY=your_64_hex_char_encryption_key_here

# ========================================
# WEEK 1: CORE OPTIMIZATION SERVICES
# ========================================

# Redis Configuration
REDIS_URL=redis://localhost:6379

# LLM Service Configuration
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=mixtral-8x7b-32768
LLM_TIMEOUT=30000
LLM_MAX_RETRIES=3

# Cache Service Configuration
CACHE_TTL_SECONDS=3600
USE_REVIEW_CACHE=true

# Cost Tracking Configuration
BUDGET_USD=100
BUDGET_CHECK_ENABLED=true

# ========================================
# WEEK 2: MONITORING & RESILIENCE
# ========================================

# Sentry Error Tracking
SENTRY_DSN=https://your_sentry_dsn
SENTRY_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# Model Selection Strategy
# Options: 'balanced', 'quality', 'speed', 'cost'
MODEL_SELECTION_STRATEGY=balanced

# Queue Configuration
QUEUE_CONCURRENCY_REVIEW=3
QUEUE_CONCURRENCY_SCORE=2
QUEUE_CONCURRENCY_PORTFOLIO=2
QUEUE_TIMEOUT_REVIEW=300000

# ========================================
# WEEK 3: ANALYTICS & MONITORING
# ========================================

# Analytics Service
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=30

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# ========================================
# WEEK 4: LOGGING & DEPLOYMENT
# ========================================

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Release Info (for Sentry & monitoring)
RELEASE_VERSION=1.0.0

# Deployment
DEPLOYMENT_ENV=production
AUTO_MIGRATE=false

# Optional: Email notifications for critical alerts
NOTIFICATION_EMAIL=ops@devhubs.com
SLACK_WEBHOOK_URL=your_slack_webhook_url

# ========================================
# FEATURE FLAGS
# ========================================

# Enable/disable Week 1-4 features
ENABLE_CACHE_SERVICE=true
ENABLE_COST_TRACKING=true
ENABLE_DEAD_LETTER_QUEUE=true
ENABLE_MONITORING=true
ENABLE_ANALYTICS=true
ENABLE_MODEL_SELECTOR=true
ENABLE_PROMPT_OPTIMIZER=true

# ========================================
# SECURITY & CORS
# ========================================

# Frontend origin — used for strict CORS allowlist (no wildcard in prod)
FRONTEND_URL=https://app.devhubs.io

# Optional: comma-separated additional origins (e.g. preview deployments)
# EXTRA_ALLOWED_ORIGINS=https://preview-123.devhubs.io

# ========================================
# EMAIL
# ========================================
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=notifications@devhubs.io
EMAIL_FROM_NAME=DevHubs

# ========================================
# VERIFICATION ENGINE (Phase 1+)
# ========================================

# Eval worker on VPS3 — how long VPS1 waits for execution results before degrading
EVAL_AWAIT_TIMEOUT_MS=120000

# Set to 'true' to skip eval dispatch (useful for dev without VPS3)
EVAL_DISABLED=false

# Review diff limits
REVIEW_MAX_FILES=3
REVIEW_MAX_LINES_PER_FILE=250
REVIEW_MAX_PATCH_CHARS=8000
REVIEW_MAX_PROMPT_CHARS=7000

# ========================================
# VPS3 EVAL WORKER ONLY (do not set on VPS1/VPS2)
# ========================================

# Path to hidden test suites on VPS3
HIDDEN_TESTS_PATH=/opt/devhubs/hidden-tests

# Workspace for ephemeral eval (cleaned after each job)
EVAL_WORKSPACE=/opt/devhubs/eval-workspace

# Docker container execution timeout (ms)
EVAL_TIMEOUT_MS=90000

# Docker image build timeout (ms)
DOCKER_BUILD_TIMEOUT_MS=120000

# Concurrent eval jobs on VPS3
EVAL_QUEUE_CONCURRENCY=2

# Default test command run inside student container
# Runner.sh is preferred when available
EVAL_TEST_COMMAND=if [ -f /hidden-tests/runner.sh ]; then /bin/sh /hidden-tests/runner.sh; elif [ -f package.json ]; then npm test 2>&1; else echo "No test runner found"; fi
